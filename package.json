{
  "name": "burn-watch",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "typecheck": "turbo typecheck",
    "db:migrate": "turbo db:migrate --filter=@burn-watch/api",
    "db:push": "turbo db:push --filter=@burn-watch/api",
    "agent:build": "turbo build --filter=@burn-watch/agent"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@better-fetch/fetch": "^1.3.1",
    "@nanostores/react": "^1.1.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "better-call": "^2.0.4",
    "defu": "^6.1.7",
    "jose": "^6.2.3",
    "kysely": "^0.29.2",
    "nanostores": "^1.3.0"
  }
}
