{
  "name": "burn-watch",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "typecheck": "turbo typecheck",
    "db:migrate": "turbo db:migrate --filter=@burn-watch/api",
    "db:push": "turbo db:push --filter=@burn-watch/api",
    "agent:build": "turbo build --filter=@burn-watch/agent"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.0.0"
  }
}
